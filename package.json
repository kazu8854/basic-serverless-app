{
  "name": "basic-serverless-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:mock": "npm run dev:mock --workspaces --if-present",
    "dev:aws": "npm run dev:aws --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "deploy": "npm run build && npm run deploy --workspace=infrastructure"
  }
}
